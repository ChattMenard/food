{
  "name": "main",
  "version": "1.0.0",
  "description": "Main - AI-Powered Meal Planner",
  "type": "module",
  "scripts": {
    "start": "lsof -ti :8080 | xargs -r kill; npx serve -p 8080 www",
    "stop": "lsof -ti :8080 | xargs -r kill",
    "build:css": "./node_modules/.bin/tailwindcss -i www/css/tailwind.css -o www/css/output.css --watch",
    "build:css:once": "./node_modules/.bin/tailwindcss -i www/css/tailwind.css -o www/css/output.css",
    "build:data": "python3 scripts/build_dataset.py",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "eslint www/js --ext .js",
    "lint:fix": "eslint www/js --ext .js --fix",
    "format": "prettier --write www/js/**/*.js",
    "format:check": "prettier --check www/js/**/*.js",
    "validate-dataset": "python3 scripts/build_dataset.py --validate-only",
    "android": "npm run sync && CAPACITOR_ANDROID_STUDIO_PATH=/home/x99/Downloads/android-studio/bin/studio.sh npx cap open android",
    "android:build": "JAVA_HOME=/home/x99/Downloads/android-studio/jbr PATH=/home/x99/Downloads/android-studio/jbr/bin:$PATH ./android/gradlew -p android :app:assembleDebug",
    "deploy": "npm run sync && JAVA_HOME=/home/x99/Downloads/android-studio/jbr PATH=/home/x99/Downloads/android-studio/jbr/bin:$PATH ./android/gradlew -p android clean :app:assembleDebug && ~/Android/Sdk/platform-tools/adb install -r android/app/build/outputs/apk/debug/app-debug.apk && ~/Android/Sdk/platform-tools/adb shell am start -n com.main.app/.MainActivity",
    "ios": "cap add ios && cap open ios",
    "sync": "ANDROID_HOME=~/Android/Sdk JAVA_HOME=/home/x99/Downloads/android-studio/jbr cap sync"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.2.2",
    "babel-jest": "^30.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.1",
    "fake-indexeddb": "^6.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "serve": "^14.2.4",
    "tailwindcss": "^4.2.2"
  }
}
