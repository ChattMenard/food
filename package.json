{
  "name": "fridge-to-fork",
  "version": "1.0.0",
  "description": "Fridge to Fork - AI-Powered Meal Planner & Shopping Assistant",
  "type": "module",
  "scripts": {
    "start": "node scripts/kill-port.js 8080 && npx serve -p 8080 www",
    "stop": "node scripts/kill-port.js 8080",
    "build:css": "./node_modules/.bin/tailwindcss -i www/css/tailwind.css -o www/css/output.css --watch",
    "build:css:once": "./node_modules/.bin/tailwindcss -i www/css/tailwind.css -o www/css/output.css",
    "build:ts": "tsc",
    "build:ts:watch": "tsc --watch",
    "build": "npm run build:css:once && npm run build:ts",
    "build:prod": "npm run build:css:once && node scripts/build-production.js",
    "build:analyze": "node scripts/build-production.js --analyze",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "backup:create": "bash scripts/backup-data.sh create",
    "backup:restore": "bash scripts/backup-data.sh restore",
    "backup:list": "bash scripts/backup-data.sh list",
    "build:data": "python3 scripts/build_dataset.py",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium --reporter=line",
    "lint": "eslint www/js --ext .js,.ts",
    "lint:fix": "eslint www/js --ext .js,.ts --fix",
    "format": "prettier --write www/js/**/*.{js,ts}",
    "format:check": "prettier --check www/js/**/*.{js,ts}",
    "validate-dataset": "python3 scripts/build_dataset.py --validate-only",
    "android": "npm run sync && npx cap open android",
    "android:studio": "npm run sync && CAPACITOR_ANDROID_STUDIO_PATH=${ANDROID_STUDIO_PATH:-/opt/android-studio/bin/studio.sh} npx cap open android",
    "android:debug": "bash scripts/optimize-debug.sh",
    "android:wireless": "bash scripts/wireless-debug.sh",
    "android:build": "./android/gradlew -p android :app:assembleDebug",
    "deploy": "bash scripts/deploy-android.sh",
    "ios": "cap add ios && cap open ios",
    "sync": "npx cap sync",
    "setup:env": "bash scripts/setup-env.sh",
    "validate:env": "bash scripts/validate-env.sh"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-jest": "^30.3.0",
    "dompurify": "^3.4.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.2.1",
    "fake-indexeddb": "^6.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "serve": "^14.2.4",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
