# Local development environment variables
# Copy this file to `.env.local` and fill in real values.

# ============================================
# GitHub OAuth (for auth + workflow-related tooling)
# ============================================
GITHUB_OAUTH_CLIENT_ID="your_github_oauth_client_id"
GITHUB_OAUTH_CLIENT_SECRET="your_github_oauth_client_secret"

# ============================================
# Android Development Configuration
# ============================================
# Note: The deploy script and npm scripts use sensible defaults for standard Android Studio 
# installations. Only set these if your setup differs from the default locations.

# Android SDK location (auto-detects ~/Android/Sdk if not set)
# ANDROID_HOME=/path/to/Android/Sdk

# Android Studio JDK location (auto-detects standard locations if not set)
# JAVA_HOME=/path/to/jdk

# ADB binary path (auto-detects from ANDROID_HOME if not set)
# ADB_BIN=/path/to/adb

# Specific device serial for deployment (optional - auto-selects first device)
# ADB_SERIAL=emulator-5554

# Capacitor Android Studio path (auto-detects if not set)
# CAPACITOR_ANDROID_STUDIO_PATH=/path/to/android-studio/bin/studio.sh
