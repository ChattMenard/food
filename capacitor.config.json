{
  "appId": "com.main.app",
  "appName": "Main",
  "webDir": "www",
  "bundledWebRuntime": false,
  "plugins": {
    "GoogleAuth": {
      "scopes": ["email", "profile"],
      "serverClientId": "593330232333-ibpbcc7qme63ku7a3e67i2dg33n9f1en.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "ios": {
    "scheme": "Main"
  },
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "liveReload": {
    "enabled": false,
    "ignore": [
      "www/js/__tests__/**",
      "www/data/**",
      "**/*.test.js",
      "**/*.spec.js"
    ]
  }
}
